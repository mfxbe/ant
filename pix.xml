<?xml version="1.0" encoding="UTF-8"?>
<app xmlns="https://sp1rit.arpa/pixiewood/">
        <metainfo>
                <component xmlns="https://specifications.freedesktop.org/metainfo/1.0" type="desktop">
                        <id>de.mfxbe.GiDAndroidApp</id>
                        <name>GiDAndroidApp</name>
                        <releases>
                                <release version="0">
                                        <description>
                                                <p>Initial release</p>
                                        </description>
                                </release>
                        </releases>
                </component>
        </metainfo>
        <style>
                <theme name="gtk"/>
                <icon type="generate">
                        <drawable target="foreground" scale=".45" type="svg" path="src://logo.svg"/>
                        <color target="background">#FFFFFF</color>
                        <drawable target="monochrome" scale=".45" type="svg" path="src://logo.svg"/>
                </icon>
        </style>
        <dependencies>
                <glib revison="2.80.0">
                        <patch>hack</patch>
                </glib>
                <fontconfig/>
                <rsvg revision="librsvg-2.40">
                        <patch>meson-for-gdkpixbuf</patch>
                </rsvg>
                <gdk-pixbuf>
                        <patch>rsvg</patch>
                </gdk-pixbuf>
                <gtk/>
        </dependencies>
        <build target="gGiDAndroidApp">
                <architectures>
                        <arch>aarch64</arch>
                </architectures>
                <configure-options>
                        <option>--cross=cross.txt</option>
                        <option>-Dgtk:introspection=disabled</option>
                        <option>-Dglib:introspection=disabled</option>
                        <option>-Dgdk-pixbuf:introspection=disabled</option>
                </configure-options>
        </build>
</app>
