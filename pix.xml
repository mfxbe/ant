<?xml version="1.0" encoding="UTF-8"?>
<app xmlns="https://sp1rit.arpa/pixiewood/" xmlns:xi="http://www.w3.org/2001/XInclude">
	<metainfo>
		<component xmlns="https://specifications.freedesktop.org/metainfo/1.0" type="desktop">
			<id>de.mfxbe.ExampleApp</id>
			<name>Ant</name>
			<releases>
				<release version="0">
					<description>
						<p>Initial release</p>
					</description>
				</release>
			</releases>
		</component>
	</metainfo>
	<style>
		<theme name="gtk"/>
		<icon type="generate">
			<drawable target="foreground" scale=".45" type="svg" path="src://logo.svg"/>
			<color target="background">#FFFFFF</color>
			<drawable target="monochrome" scale=".45" type="svg" path="src://logo.svg"/>
		</icon>
	</style>
	<dependencies>
		<zlib/>
		<glib revison="2.80.0">
			<patch>hack</patch>
		</glib>
		<fontconfig/>
		<rsvg revision="librsvg-2.40">
			<patch>meson-for-gdkpixbuf</patch>
		</rsvg>
		<gdk-pixbuf>
			<patch>rsvg</patch>
		</gdk-pixbuf>
		<gtk/>
	</dependencies>
	<build target="ant">
		<architectures>
			<arch>aarch64</arch>
                        <arch>x86_64</arch>
		</architectures>
		<configure-options>
			<option>--cross=cross.txt</option>
		</configure-options>
	</build>
</app>
